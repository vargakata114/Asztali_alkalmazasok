<Window x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid ShowGridLines="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Text="Irányítópult" FontSize="24" HorizontalAlignment="Center"/>
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Fő adatok" Background="LightBlue"/>
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical">
            <Button Content="Frissít" Margin="5"/>
            <Button Content="Mentés" Margin="5"/>
        </StackPanel>

        <TextBlock Grid.Row="1" Grid.Column="2" Text="Grafikon" Background="LightGreen"/>
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Státusz: Aktív" VerticalAlignment="Center"/>
        <Button Grid.Row="3" Grid.Column="1" Content="Kilépés" Click="Bezaras"/>

    </Grid>
</Window>
