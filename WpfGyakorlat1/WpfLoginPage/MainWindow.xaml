<Window x:Class="WpfLoginPage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfLoginPage"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Label Content="Felhasználónév:" HorizontalAlignment="Left" Margin="204,84,0,0" VerticalAlignment="Top" Width="106"/>
        <Label Content="Jelszó:" HorizontalAlignment="Left" Margin="204,160,0,0" VerticalAlignment="Top" Width="92"/>
        <TextBox x:Name="txtFelhasznalo" HorizontalAlignment="Left" Margin="223,115,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" Height="31"/>
        <PasswordBox x:Name="txtJelszo" HorizontalAlignment="Left" Margin="223,191,0,0" VerticalAlignment="Top" Width="120" Height="30"/>
        <Button Content="BEJELENTKEZÉS" HorizontalAlignment="Left" Margin="400,142,0,0" VerticalAlignment="Top" Width="95" Height="27" Background="#FF29CF2D" Foreground="#FFF6F1F1" FontWeight="Bold" Click="btnBelepes_Click"/>
        <Button Content="MÉGSEM" HorizontalAlignment="Left" Margin="400,189,0,0" VerticalAlignment="Top" Width="95" Height="24" Click="btnMegsem_Click"/>
        <CheckBox Content="Megjegyzem a belépést" HorizontalAlignment="Left" Margin="223,269,0,0" VerticalAlignment="Top"/>
        <Image Source="/logo_kicsi_0.png"
               Width="120" Height="120" Margin="69,101,0,0"
               HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Label x:Name="fejlecText" Content="ÜDVÖZLÜNK A RENDSZERBEN!" HorizontalAlignment="Left" Margin="161,23,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.279,0.14" FontSize="22" FontWeight="Bold" Foreground="#FF0A1C73"/>

    </Grid>
</Window>
