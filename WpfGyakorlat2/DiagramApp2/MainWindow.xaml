<Window x:Class="DiagramApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DiagramApp2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <StackPanel Margin="10">
        <Button Content="Megnyitás" Click="Open_Click" Margin="10"/>
        <Button Content="Mentés" Click="Save_Click" Margin="10"/>
        <TextBox Name="txtFile" Margin="10"/>
    </StackPanel>
    
</Window>
