<Window x:Class="Feladat3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Feladat3"
        mc:Ignorable="d"
        Title="Szállítási beállítások" Height="450" Width="800">

    <StackPanel Orientation="Vertical" Margin="16">
        <Label Content="Szállítási mód:"/>
        <ComboBox x:Name="cbSzallitas" SelectedIndex="0">
            <ComboBoxItem Content="Házhozszállítás"/>
            <ComboBoxItem Content="Személyes átvétel"/>
            <ComboBoxItem Content="Expressz"/>
        </ComboBox>

        <Label Content="Csomagolás:" Margin="0,12,0,0"/>
        <RadioButton GroupName="Csomagolas" Content="Normál" IsChecked="True"/>
        <RadioButton GroupName="Csomagolas" Content="Ajándék csomagolás"/>
    </StackPanel>
</Window>
